# Outputs — surfaces key resource identifiers for CI/CD and operators
{% if 'static-site' not in services %}
output "vpc_id" {
  description = "VPC ID"
  value       = module.vpc.vpc_id
}

output "private_subnet_ids" {
  description = "Private subnet IDs"
  value       = module.vpc.private_subnets
}

output "public_subnet_ids" {
  description = "Public subnet IDs"
  value       = module.vpc.public_subnets
}
{% endif %}
{% if 'lambda' in compute_target %}
output "lambda_function_name" {
  description = "Lambda function name"
  value       = module.lambda.function_name
}

output "lambda_function_arn" {
  description = "Lambda function ARN"
  value       = module.lambda.function_arn
}
{% endif %}
{% if 'ecs-fargate' in compute_target %}
output "ecs_cluster_name" {
  description = "ECS cluster name"
  value       = module.ecs.cluster_name
}

output "ecs_service_name" {
  description = "ECS service name"
  value       = module.ecs.service_name
}
{% endif %}
{% if 'kms' in data_stores or data_stores %}
output "kms_key_id" {
  description = "KMS CMK key ID"
  value       = try(module.kms.key_id, null)
}
{% endif %}

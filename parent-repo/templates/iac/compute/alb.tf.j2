# ALB — hardened ingress for web-api
resource "aws_lb" "main" {
  #checkov:skip=CKV2_AWS_28:WAF association is attached separately via the waf module when present; add aws_wafv2_web_acl_association referencing this ALB ARN
  #checkov:skip=CKV_AWS_91:S3 access logging disabled by design — request-level detail not needed; ALB CloudWatch metrics + alarms cover observability. Re-enable by adding an access_logs block pointing at a log-delivery bucket.
  name               = "{{ project_name }}-${var.environment}-alb"
  # Internet-facing by design: the public entry point of the stack
  # (infra.yaml requests internet_facing). WAF + HTTPS-only listeners guard it.
  internal           = false #tfsec:ignore:aws-elb-alb-not-public
  load_balancer_type = "application"
  security_groups    = [var.security_group_id]
  subnets            = var.public_subnet_ids

  # Security hardening
  drop_invalid_header_fields = true          # CKV_AWS_131
  # Deletion protection only in prod — dev/uat stacks must be destroyable.
  #checkov:skip=CKV_AWS_150:Deletion protection is environment-driven (true in prod)
  enable_deletion_protection = var.environment == "prod"

  tags = {
    Name        = "{{ project_name }}-${var.environment}-alb"
    Environment = var.environment
  }
}

resource "aws_lb_target_group" "app" {
  name        = "{{ project_name }}-${var.environment}-tg"
  port        = 443
  protocol    = "HTTPS"
  vpc_id      = var.vpc_id
  target_type = "ip"

  health_check {
    path                = "/health"
    protocol            = "HTTPS"
    matcher             = "200"
    interval            = 30
    healthy_threshold   = 2
    unhealthy_threshold = 3
  }

  tags = {
    Name        = "{{ project_name }}-${var.environment}-tg"
    Environment = var.environment
  }
}

# HTTPS listener — TLS 1.2+ (CKV_AWS_2, CKV_AWS_103, CKV_AWS_378)
resource "aws_lb_listener" "https" {
  load_balancer_arn = aws_lb.main.arn
  port              = 443
  protocol          = "HTTPS"
  ssl_policy        = "ELBSecurityPolicy-TLS13-1-2-2021-06"
  certificate_arn   = var.alb_certificate_arn

  default_action {
    type             = "forward"
    target_group_arn = aws_lb_target_group.app.arn
  }
}

# HTTP listener — redirects everything to HTTPS (CKV2_AWS_20)
resource "aws_lb_listener" "http" {
  load_balancer_arn = aws_lb.main.arn
  port              = 80
  protocol          = "HTTP"

  default_action {
    type = "redirect"

    redirect {
      port        = "443"
      protocol    = "HTTPS"
      status_code = "HTTP_301"
    }
  }
}
